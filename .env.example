## Backend (server) runtime
NODE_ENV=development
PORT=3000

# MySQL connection string for Drizzle + mysql2
# If unset in NODE_ENV=development, auth uses a local file store (.data/local-auth.json) instead.
# See docs/database-integrity.md for migrations, foreign keys, and transactions.
DATABASE_URL=mysql://user:password@localhost:3306/behberg_outreach

# Public base URL used for email tracking pixel and redirects
# In production this should be your HTTPS domain (e.g. https://outreach.yourdomain.com)
APP_BASE_URL=http://localhost:3000

## SMTP (outbound email)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=outreach@yourdomain.com
SMTP_PASS=your_smtp_app_password

## Auth / session / OAuth portal
# Secret used for signing/encrypting the session cookie/token (set a long random value)
JWT_SECRET=replace_with_long_random_secret

# External OAuth portal used by the app for login flow
OAUTH_SERVER_URL=https://your-oauth-portal.example.com

# Optional: owner identity for internal notifications (if used)
OWNER_OPEN_ID=

## Local admin sign-in (username stored in users.email; default password only for first-time seed)
# Comma-separated extra allowed logins (optional). Alias: ADMIN_ALLOWLIST_EMAILS
ADMIN_ALLOWLIST=
DEFAULT_ADMIN_LOGIN=behberg
DEFAULT_ADMIN_PASSWORD=grebheb
# Set to true to require a 6-digit code emailed after password check (default: off)
AUTH_REQUIRE_EMAIL_OTP=false
# If OTP is on and login is not an email, the code is sent here (defaults to SMTP_USER)
OTP_DELIVERY_EMAIL=

## Forge proxy (used by LLM, maps proxy, storage proxy, etc.)
BUILT_IN_FORGE_API_URL=https://forge.manus.im
BUILT_IN_FORGE_API_KEY=replace_with_forge_api_key

## Frontend (Vite) variables (exposed to the browser)
VITE_APP_ID=your_app_id
VITE_OAUTH_PORTAL_URL=https://your-oauth-portal.example.com
VITE_FRONTEND_FORGE_API_URL=https://forge.manus.im
VITE_FRONTEND_FORGE_API_KEY=replace_with_frontend_forge_key_if_needed

## Frontend-only demo mode (no backend required)
# When enabled, the app uses in-browser mock data and all dashboard pages work without a server.
VITE_DEMO_MODE=false

