## Backend (server) runtime
NODE_ENV=development
PORT=3000

# MySQL connection string for Drizzle + mysql2
# If unset in NODE_ENV=development, auth uses a local file store (.data/local-auth.json) instead.
# See docs/database-integrity.md for migrations, foreign keys, and transactions.
DATABASE_URL=mysql://user:password@localhost:3306/behberg_outreach

# Public base URL used for email tracking pixel and redirects
# In production this should be your HTTPS domain (e.g. https://outreach.yourdomain.com)
APP_BASE_URL=http://localhost:3000

## SMTP (outbound email)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=outreach@yourdomain.com
SMTP_PASS=your_smtp_app_password

## Auth / session / OAuth portal
# Secret used for signing/encrypting the session cookie/token (set a long random value)
JWT_SECRET=replace_with_long_random_secret

# External OAuth portal used by the app for login flow
OAUTH_SERVER_URL=https://your-oauth-portal.example.com

## Firebase (social sign-in on /login and /signup — Google, Microsoft, GitHub, Apple)
# The app does not use Firebase Email/Password; enable only the OAuth providers you need in Firebase Console.
# Server: verify ID tokens — use ONE of:
# - Path to the service account JSON from Firebase Console
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json
# - Or paste the entire JSON as one line (PaaS). Never commit real secrets.
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}
# Optional project id if credentials already include it (or for ADC-only setups):
# FIREBASE_PROJECT_ID=your-project
#
# Client (Vite) — Web app config from Firebase Console → Project settings → Your apps:
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
# VITE_FIREBASE_PROJECT_ID=your-project
# VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=

# Optional: owner identity for internal notifications (if used)
OWNER_OPEN_ID=

## Local admin sign-in (username stored in users.email; default password only for first-time seed)
# Comma-separated extra allowed logins (optional). Alias: ADMIN_ALLOWLIST_EMAILS
ADMIN_ALLOWLIST=
# Initial platform operator (sign in at /login with username + password). Change the password in production.
# Example credentials when using the defaults below: username `behberg`, password `grebheb`.
DEFAULT_ADMIN_LOGIN=behberg
DEFAULT_ADMIN_PASSWORD=grebheb
# After pulling migrations, run `pnpm db:migrate` (0007 adds `superadmin` enum; 0008 adds `accountDisabled`).
# Superadmin console: /app/superadmin — grant `superadmin` to another user, then use “Disable default operator” on this row.
# The console is also available via `auth.me.isPlatformOperator` for this login before migration 0007.
# First-time seed still sets role `superadmin` for `login:behberg` when applicable.
# Set to true to require a 6-digit code emailed after password check (default: off)
AUTH_REQUIRE_EMAIL_OTP=false
# If OTP is on and login is not an email, the code is sent here (defaults to SMTP_USER)
OTP_DELIVERY_EMAIL=

## Optional scheduler toggles
# Set true to disable email and signals background schedulers
DISABLE_SCHEDULER=false
# Set true to disable only signals scheduler
DISABLE_SIGNALS_SCHEDULER=false

## Forge proxy (used by LLM, maps proxy, storage proxy, etc.)
BUILT_IN_FORGE_API_URL=https://forge.manus.im
BUILT_IN_FORGE_API_KEY=replace_with_forge_api_key

## Frontend (Vite) variables (exposed to the browser)
VITE_APP_ID=your_app_id
VITE_OAUTH_PORTAL_URL=https://your-oauth-portal.example.com
VITE_FRONTEND_FORGE_API_URL=https://forge.manus.im
VITE_FRONTEND_FORGE_API_KEY=replace_with_frontend_forge_key_if_needed

## Frontend-only demo mode (no backend required)
# When enabled, the app uses in-browser mock data and all dashboard pages work without a server.
VITE_DEMO_MODE=false

## Prospecting (Basic v1 - cost free)
# Note: This feature crawls public company pages (about/team/leadership/contact).
# Keep limits low to avoid accidental high traffic.
PROSPECTING_V1_MAX_ACTIVE_RUNS_PER_ORG=2
PROSPECTING_V1_RUN_TTL_MINUTES=20
PROSPECTING_V1_HARD_TIMEOUT_MINUTES=60

